[Unit]
Description=Chainsaw Ops weather + Victorian alerts -> BigQuery (4-hourly)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/chainsaw-ops
Environment=FLASK_APP=wsgi.py
Environment=PATH=/opt/chainsaw-ops/venv/bin
ExecStart=/opt/chainsaw-ops/venv/bin/flask fetch-weather
TimeoutStartSec=5min
StandardOutput=journal
StandardError=journal
